classDiagram
direction TB

class Program {
    +MapControllers()
    +MapHub("/hubs/collaboration")
    +MapGet("/api/health")
}

class AuthenticatedControllerBase {
    #RequireUserAsync(cancellationToken) User
    #GetBearerToken() string?
}

class UserController {
    +Register(RegisterRequest) AuthSessionDto
    +Login(LoginRequest) AuthSessionDto
    +Logout() IActionResult
    +Me() UserDto
    +UpdateProfile(UpdateUserRequest) UserDto
    +DeleteAccount() IActionResult
    +ResetPassword(ResetPasswordRequest) IActionResult
}

class ProjectController {
    +List() IReadOnlyList~ProjectDto~
    +Create(CreateProjectRequest) ActionResult~ProjectDto~
    +Get(id) ProjectDto
    +Update(id, UpdateProjectRequest) ProjectDto
    +AddCustomComponent(id, CustomComponentDto) ProjectDto
    +Delete(id) IActionResult
}

class ComponentController {
    +List() IReadOnlyList~CustomComponentDto~
    +Create(CustomComponentDto) ActionResult~CustomComponentDto~
    +Get(id) CustomComponentDto
    +Delete(id) IActionResult
}

class CollaborationHub {
    +CreateSession(JsonElement, displayName) CollaborationSessionDto
    +JoinSession(sessionId, displayName) CollaborationSessionDto
    +LeaveSession(sessionId) void
    +UpdateCircuit(sessionId, JsonElement) void
    +UpdateCursor(sessionId, CursorPositionDto) void
    +OnDisconnectedAsync(exception) Task
}

class UserService {
    +RegisterAsync(RegisterRequest) AuthSessionDto
    +LoginAsync(LoginRequest) AuthSessionDto
    +FindUserByTokenAsync(token) User?
    +LogoutAsync(token) Task
    +UpdateProfileAsync(User, UpdateUserRequest) UserDto
    +ResetPasswordAsync(ResetPasswordRequest) Task
    +DeleteAccountAsync(User) Task
}

class ProjectService {
    +ListProjectsAsync(ownerId) IReadOnlyList~ProjectDto~
    +GetProjectAsync(ownerId, projectId) ProjectDto
    +CreateProjectAsync(ownerId, CreateProjectRequest) ProjectDto
    +UpdateProjectAsync(ownerId, projectId, UpdateProjectRequest) ProjectDto
    +AddCustomComponentAsync(ownerId, projectId, CustomComponentDto) ProjectDto
    +DeleteProjectAsync(ownerId, projectId) Task
}

class ComponentService {
    +ListComponentsAsync(ownerId) IReadOnlyList~CustomComponentDto~
    +GetComponentAsync(ownerId, componentId) CustomComponentDto
    +CreateComponentAsync(ownerId, CustomComponentDto) CustomComponentDto
    +DeleteComponentAsync(ownerId, componentId) Task
}

class CollaborationSessionStore {
    +CreateSession(hostUserId, connectionId, displayName, currentCircuit) CollaborationSessionDto
    +JoinSession(sessionId, userId, displayName, connectionId) CollaborationSessionDto
    +LeaveSession(sessionId, connectionId) CollaborationLeaveResult
    +UpdateCircuit(sessionId, connectionId, currentCircuit) CircuitUpdatedDto
    +UpdateCursor(sessionId, connectionId, cursorPosition) CollaborationParticipantDto
}

class UserRepository {
    +FindByEmailAsync(normalizedEmail) User?
    +FindSessionAsync(token) UserSession?
    +Add(User) void
    +AddSession(UserSession) void
    +Remove(User) void
    +RemoveSession(UserSession) void
    +SaveChangesAsync() Task
}

class ProjectRepository {
    +ListByOwnerAsync(ownerId) IReadOnlyList~Project~
    +FindForOwnerAsync(ownerId, projectId) Project?
    +Add(Project) void
    +Remove(Project) void
    +SaveChangesAsync() Task
}

class ComponentRepository {
    +ListByOwnerAsync(ownerId) IReadOnlyList~Component~
    +FindForOwnerAsync(ownerId, componentId) Component?
    +Add(Component) void
    +Remove(Component) void
    +SaveChangesAsync() Task
}

class BitFlowDbContext {
    +Users DbSet~User~
    +Sessions DbSet~UserSession~
    +Projects DbSet~Project~
    +Components DbSet~Component~
}

class User {
    +Id string
    +Name string
    +Email string
    +NormalizedEmail string
    +PasswordHash string
    +CreatedAt DateTimeOffset
}

class UserSession {
    +Token string
    +UserId string
    +CreatedAt DateTimeOffset
    +ExpiresAt DateTimeOffset
}

class Project {
    +Id string
    +OwnerId string
    +Name string
    +Description string
    +CircuitJson string
    +InputSignalsJson string
    +CustomComponentsJson string
    +CreatedAt DateTimeOffset
    +UpdatedAt DateTimeOffset
}

class Component {
    +Id string
    +OwnerId string
    +Name string
    +ComponentJson string
    +CreatedAt DateTimeOffset
}

Program --> UserController
Program --> ProjectController
Program --> ComponentController
Program --> CollaborationHub

AuthenticatedControllerBase <|-- UserController
AuthenticatedControllerBase <|-- ProjectController
AuthenticatedControllerBase <|-- ComponentController

UserController --> UserService
ProjectController --> ProjectService
ProjectController --> UserService
ComponentController --> ComponentService
ComponentController --> UserService
CollaborationHub --> CollaborationSessionStore
CollaborationHub --> UserService

UserService --> UserRepository
ProjectService --> ProjectRepository
ComponentService --> ComponentRepository

UserRepository --> BitFlowDbContext
ProjectRepository --> BitFlowDbContext
ComponentRepository --> BitFlowDbContext

BitFlowDbContext --> User
BitFlowDbContext --> UserSession
BitFlowDbContext --> Project
BitFlowDbContext --> Component

